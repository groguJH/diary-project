DB_URL=jdbc:postgresql://aws-0-your-region.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=replace-with-supabase-database-password

JWT_SECRET=replace-with-long-random-secret-at-least-32-characters
JWT_ACCESS_TOKEN_VALIDITY_SECONDS=3600
JWT_REFRESH_TOKEN_VALIDITY_SECONDS=1209600

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

KEEP_ALIVE_ENABLED=false
KEEP_ALIVE_URL=https://your-render-service.onrender.com/api/health
KEEP_ALIVE_FIXED_DELAY_MS=600000
KEEP_ALIVE_INITIAL_DELAY_MS=30000
